  "query": "\n            SELECT id, sender_id, recipient_id, content, created_at\n            FROM private_messages\n            WHERE (sender_id = $1 AND recipient_id = $2)\n               OR (sender_id = $2 AND recipient_id = $1)\n            ORDER BY created_at DESC\n            LIMIT $3\n            ",
