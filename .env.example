# Vraie valeur donnee au kickoff -- placeholder en attendant
OPSWARDEN_KICKOFF_TOKEN="Romeo Cavazza VIGIL2026"
DATABASE_URL="postgres://opswarden:opswarden@localhost:5433/opswarden"
JWT_SECRET="super_secret_dev_key"

# --- Automatisation Team : coffre de secrets ---
# Cle AES-256 du coffre (64 hex = 32 octets). Defaut dev si absent.
# Generer : openssl rand -hex 32
OPSWARDEN_VAULT_KEY=""
# Les secrets GitHub/HTTP et les règles se configurent dans la Team ; aucune
# variable d'environnement métier globale n'est acceptée.

# --- RTC2 : API externe GIF (optionnel en dev) ---
# Cle serveur GIPHY pour la recherche de GIFs dans la timeline.
# Ne jamais exposer au client web ; le serveur doit proxy les appels.
GIPHY_API_KEY=""

# --- OAuth Google (optionnel, requis pour les boutons Google du client) ---
# Redirect URI a declarer dans Google Cloud Console:
# http://localhost:8080/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8080/api/auth/google/callback"
OPSWARDEN_WEB_ORIGIN="http://localhost:4242"
# Optional Compose-only override. Compose serves the web client on 8081 by
# default while `just web-dev` keeps using OPSWARDEN_WEB_ORIGIN above.
OPSWARDEN_COMPOSE_WEB_ORIGIN="http://localhost:8081"
